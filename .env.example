CVD_HOST=127.0.0.1
CVD_PORT=8080
CVD_DB_PATH=data/cvd.sqlite3
CVD_COOKIE_SECURE=0
CVD_SESSION_DAYS=7

# Set these before first production start.
CVD_ADMIN_EMAIL=admin@example.com
CVD_ADMIN_PASSWORD=change-this-long-password

# On VPS this should point to the LM Studio host reachable through VPN.
LM_STUDIO_API_URL=http://10.8.0.2:1234/v1/chat/completions
LM_STUDIO_MODEL=healtheart-cvd-engine
LM_STUDIO_TIMEOUT_SECONDS=300
LM_STUDIO_MAX_TOKENS=1024
LM_STUDIO_TEMPERATURE=0.2
CVD_MAX_REQUEST_BYTES=2097152
CVD_BACKUP_DIR=backups
